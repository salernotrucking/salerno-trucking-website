---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
}
const { eyebrow, title, text } = Astro.props;
---
<section class="page-hero">
  <div class="container narrow reveal">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="lead">{text}</p>
  </div>
</section>
