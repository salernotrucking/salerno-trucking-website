---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout title="About | Salerno Trucking" description="Learn about Salerno Trucking, a family-owned concrete delivery and fleet capacity company founded in 2009.">
  <PageHero eyebrow="Our Story" title="Built on Relationships. Driven by Responsibility." text="Since 2009, Salerno Trucking has built its reputation by showing up professionally, communicating clearly, and treating every customer's success as our responsibility." />

  <section class="section">
    <div class="container split">
      <div class="reveal">
        <p class="eyebrow">Who We Are</p>
        <h2>A Family Business Built for Long-Term Partnerships</h2>
      </div>
      <div class="reveal">
        <p class="lead">Salerno Trucking provides professional mixer truck capacity and concrete delivery services across the United States.</p>
        <p>We support ready-mix producers that need dependable trucks and experienced operators, and concrete placement contractors who need reliable delivery and straightforward communication. Our work spans commercial, industrial, residential, and infrastructure projects.</p>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">Our Foundation</p>
        <h2>Values That Guide Every Decision</h2>
      </div>
      <div class="values-grid">
        <article class="reveal"><h3>Respect</h3><p>For our partners, their customers, our operators, and every jobsite.</p></article>
        <article class="reveal"><h3>Integrity</h3><p>We communicate honestly, price transparently, and do what we say.</p></article>
        <article class="reveal"><h3>Stewardship</h3><p>We care for equipment, relationships, and opportunities entrusted to us.</p></article>
        <article class="reveal"><h3>Responsibility</h3><p>We take ownership of our performance and its impact on your operation.</p></article>
      </div>
    </div>
  </section>

  <section class="section dark-section">
    <div class="container split">
      <div class="reveal"><p class="eyebrow">Mission</p><h2>Professionalism Delivered.</h2></div>
      <div class="reveal"><p class="lead">To strengthen our partners' operations through reliable fleet capacity, experienced operators, transparent service, and a standard of professionalism that protects every relationship.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="reveal"><p class="eyebrow">Vision</p><h2>Partnerships Built to Last.</h2></div>
      <div class="reveal"><p class="lead">To become the concrete industry's most trusted fleet capacity and delivery partner—known nationwide for accountability, communication, and dependable service.</p></div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container centered reveal">
      <h2>Put Our Experience to Work for Your Operation.</h2>
      <a class="button button-light" href="/partner-with-us">Partner With Us</a>
    </div>
  </section>
</Layout>
