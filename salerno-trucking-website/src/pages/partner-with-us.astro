---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout title="Partner With Us | Salerno Trucking" description="Contact Salerno Trucking about mixer truck fleet capacity or concrete delivery services.">
  <PageHero eyebrow="Start a Conversation" title="Let's Build Something Strong Together." text="Tell us what your operation or project needs. Our team will follow up to discuss capacity, scheduling, and the right service approach." />

  <section class="section">
    <div class="container contact-grid">
      <div class="reveal">
        <p class="eyebrow">Contact Salerno Trucking</p>
        <h2>Professional Service Starts With Clear Communication.</h2>
        <p class="lead">Use the form to discuss ready-mix fleet support, concrete delivery, project requirements, or a long-term partnership.</p>
        <div class="contact-details">
          <a href="tel:+10000000000"><strong>Phone</strong><span>(000) 000-0000</span></a>
          <a href="mailto:info@salernotrucking.com"><strong>Email</strong><span>info@salernotrucking.com</span></a>
        </div>
      </div>

      <form class="contact-form reveal" name="partner-inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you">
        <input type="hidden" name="form-name" value="partner-inquiry" />
        <p class="hidden"><label>Do not fill this out: <input name="bot-field" /></label></p>
        <div class="field-row">
          <label>Name<input required type="text" name="name" autocomplete="name" /></label>
          <label>Company<input type="text" name="company" autocomplete="organization" /></label>
        </div>
        <div class="field-row">
          <label>Phone<input required type="tel" name="phone" autocomplete="tel" /></label>
          <label>Email<input required type="email" name="email" autocomplete="email" /></label>
        </div>
        <label>Project Type
          <select required name="project-type">
            <option value="">Select one</option>
            <option>Ready-Mix Producer Fleet Capacity</option>
            <option>Concrete Delivery</option>
            <option>Long-Term Contract</option>
            <option>Seasonal Support</option>
            <option>Other</option>
          </select>
        </label>
        <label>Message<textarea required name="message" rows="6"></textarea></label>
        <button class="button" type="submit">Submit Inquiry</button>
      </form>
    </div>
  </section>
</Layout>
